# RADAR — Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# --- AI Provider Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # optional — Gemini-only mode works without this

# --- Geolocation API ---
# ip-api.com is used by default (free, no key needed, 45 req/min)
# Set GEO_PROVIDER=ipinfo and add key below to use ipinfo.io instead
GEO_PROVIDER=ipapi
GEO_API_KEY=                                     # only needed if GEO_PROVIDER=ipinfo

# --- Application Config ---
BACKEND_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
AI_PROVIDER=gemini                               # gemini | claude
LOG_LEVEL=INFO

# --- Security ---
# Set to a random 32-char string in production
SECRET_KEY=change_me_in_production_32chars_min

# --- Database ---
DATABASE_PATH=./radar.db

# --- Replay Engine ---
REPLAY_MAX_EVENTS_PER_SEC=500
